{
	"name": "architecture-playground",
	"version": "1.6.1",
	"private": true,
	"license": "MIT",
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"ui": "pnpm --filter @workspace/ui ui",
		"check-types": "turbo run check-types",
		"db:up": "docker compose up -d postgres",
		"db:down": "docker compose down",
		"db:logs": "docker compose logs -f postgres",
		"db:migrate": "pnpm --filter @workspace/database db:migrate",
		"db:generate": "pnpm --filter @workspace/database db:generate",
		"db:studio": "DATABASE_URL=\"${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/architecture_playground?schema=public}\" pnpm --filter @workspace/database exec prisma studio"
	},
	"devDependencies": {
		"@workspace/eslint-config": "workspace:*",
		"@workspace/typescript-config": "workspace:*",
		"prettier": "catalog:",
		"prettier-plugin-tailwindcss": "catalog:",
		"turbo": "2.6.0"
	},
	"packageManager": "pnpm@10.15.0",
	"engines": {
		"node": ">=22"
	}
}
